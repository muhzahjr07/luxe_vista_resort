<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    tools:context=".SplashActivity">

    <!-- Main Logo -->
    <ImageView
        android:id="@+id/ivMainLogo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_luxevista_logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="200dp"/>

    <!-- App Title -->
    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LuxeVista Resort"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/forestGreen"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/ivMainLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- App Subtitle -->
    <TextView
        android:id="@+id/tvAppSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Experience the Pearl of the Indian Ocean"
        android:textSize="16sp"
        android:textColor="@color/earthBrown"
        android:layout_marginTop="8dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvAppTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Loading Indicator -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:indeterminateTint="@color/secondaryColor"
        app:layout_constraintTop_toBottomOf="@id/tvAppSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Loading Text -->
    <TextView
        android:id="@+id/tvLoadingText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Loading..."
        android:textSize="14sp"
        android:textColor="@color/textPrimary"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/progressBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Bottom Text -->
    <TextView
        android:id="@+id/tvBottomText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome to your safe haven!"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/secondaryColor"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toTopOf="@id/tvDeveloperCredit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Developer Credit -->
    <TextView
        android:id="@+id/tvDeveloperCredit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="An app Developed by Muhammad Zaharan CL/HDCSE/CMU/123/92"
        android:textSize="12sp"
        android:textColor="@color/textPrimary"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/tvCopyright"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Copyright -->
    <TextView
        android:id="@+id/tvCopyright"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="© 2025 All Rights Reserved"
        android:textSize="12sp"
        android:textColor="@color/textPrimary"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    tools:context=".InfoActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Header -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/headerCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ℹ️ Resort Information"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/primaryColor"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Everything you need to know about LuxeVista"
                    android:textSize="14sp"
                    android:textColor="@color/textSecondary"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- About Resort Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/aboutCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/headerCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="About LuxeVista Resort"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/primaryColor"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Welcome to LuxeVista Resort, where luxury meets the beauty of Sri Lanka. Nestled on the pristine shores of the Indian Ocean, our resort offers an unparalleled experience of relaxation and adventure in the Pearl of the Indian Ocean.\n\nWith world-class amenities, authentic Sri Lankan cuisine, and breathtaking ocean views, we provide the perfect escape for discerning travelers seeking the ultimate in comfort and service while experiencing the rich culture and natural beauty of Sri Lanka."
                    android:textSize="14sp"
                    android:textColor="@color/textSecondary"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Attractions Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/attractionsCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/aboutCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sri Lankan Attractions"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/primaryColor"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🏖️ Unawatuna Beach - 5 min walk\n🌊 Hikkaduwa Coral Reef - 10 min boat ride\n🏛️ Galle Fort Lighthouse - 15 min drive\n🌴 Royal Botanical Gardens - On-site\n🏄‍♂️ Water Sports Center - On-site\n🎭 Kandy Cultural Show - 2 hours drive\n⛰️ Adam's Peak Hiking - 3 hours drive\n🛍️ Pettah Local Markets - 30 min drive\n🐘 Pinnawala Elephant Orphanage - 1 hour drive\n🏰 Sigiriya Rock Fortress - 4 hours drive"
                    android:textSize="14sp"
                    android:textColor="@color/textSecondary"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="2dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Contact Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/contactCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/attractionsCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contact Us"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/primaryColor"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📍 Colombo, Sri Lanka\n📞 +94 11 234 5678\n✉️ info@luxevistaresort.lk\n🌐 www.luxevistaresort.lk\n🕒 24/7 Concierge Service\n✈️ Colombo International Airport - 30 min"
                    android:textSize="14sp"
                    android:textColor="@color/textSecondary"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="2dp"/>

                <!-- Contact Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCall"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📞 Call"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp"
                        android:layout_marginEnd="4dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEmail"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="✉️ Email"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnWebsite"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🌐 Website"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp"
                        android:layout_marginEnd="4dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLocation"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📍 Location"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp"
                        android:layout_marginStart="4dp"/>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Amenities Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/amenitiesCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/contactCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Resort Amenities"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/primaryColor"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🏊‍♂️ Infinity Pool with Indian Ocean View\n🍽️ 3 Authentic Sri Lankan Restaurants\n🍸 Rooftop Bar &amp; Lounge\n💆‍♀️ Ayurvedic Spa &amp; Wellness Center\n🏋️‍♂️ State-of-the-Art Fitness Center\n🎾 Tennis Courts\n🏌️‍♂️ Golf Course (18-hole)\n👶 Kids Club &amp; Activities\n🅿️ Valet Parking\n🛎️ 24/7 Concierge Service\n✈️ Airport Shuttle Service\n🌐 Free High-Speed WiFi\n🍵 Traditional Tea Ceremony\n🎭 Cultural Entertainment\n🏖️ Private Beach Access"
                    android:textSize="14sp"
                    android:textColor="@color/textSecondary"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="2dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>